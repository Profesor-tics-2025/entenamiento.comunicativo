# Entrenamiento Comunicativo — Variables de entorno de producción
# Copia este archivo como .env y rellena los valores reales

# ── Base de datos MariaDB ──────────────────────────────────────────────────────
# Usa socket Unix si MariaDB corre en el mismo servidor (más rápido y más seguro)
DB_HOST=localhost
DB_PORT=3306
DB_USER=entrenamiento
DB_PASSWORD=CAMBIA_ESTO_POR_CONTRASENA_SEGURA
DB_NAME=entrenamiento_comunicativo
# Descomenta si usas socket Unix (más seguro que TCP en local):
# DB_SOCKET=/var/run/mysqld/mysqld.sock

# ── JWT ─────────────────────────────────────────────────────────────────────────
# Genera con: openssl rand -base64 64
JWT_SECRET=GENERA_UN_SECRETO_LARGO_Y_ALEATORIO_AQUI

# ── CORS — dominio exacto del frontend (sin trailing slash) ────────────────────
FRONTEND_URL=https://comunicacion.cibermedida.es

# ── API Keys ───────────────────────────────────────────────────────────────────
EMERGENT_LLM_KEY=sk-emergent-XXXXXXXXXXXXXXXX

# ── Puerto del servidor Node.js ────────────────────────────────────────────────
PORT=3002
